<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="550.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project101.Controller">

   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox prefHeight="50.0">
               <children>
                  <Label prefWidth="70.0" text="Name:" />
                  <TextField fx:id="txtName" />
               </children>
            </HBox>

            <HBox prefHeight="50.0">
               <children>
                  <Label prefWidth="70.0" text="Course:" />
                  <TextField fx:id="txtCourse" />
               </children>
            </HBox>

            <HBox prefHeight="50.0">
               <children>
                  <Label prefWidth="70.0" text="Year Level:" />
                  <ChoiceBox fx:id="cbYear" prefWidth="150.0" />
               </children>
            </HBox>

            <HBox prefHeight="50.0" prefWidth="100.0" spacing="10">
               <children>
                  <Button onAction="#addStudent" prefWidth="55.0" text="Add" />
                  <Button onAction="#updateStudent" text="Update" />
                  <Button onAction="#deleteStudent" prefWidth="55.0" text="Delete" />
                  <Button onAction="#clearFields" prefWidth="55.0" text="Clear" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>

   <bottom>
      <TableView fx:id="table" prefHeight="303.0" prefWidth="480.0" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colId" prefWidth="105.0" text="ID" />
            <TableColumn fx:id="colName" prefWidth="125.0" text="Name" />
            <TableColumn fx:id="colCourse" prefWidth="125.0" text="Course" />
            <TableColumn fx:id="colYear" prefWidth="125.0" text="Year Level" />
         </columns>
      </TableView>
   </bottom>

   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</BorderPane>